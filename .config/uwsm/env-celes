# uwsm session environment — celes (AMD-primary hybrid laptop)
# NVIDIA env vars are intentionally absent: celes drives the display with AMD.
# To run something on NVIDIA: __NV_PRIME_RENDER_OFFLOAD=1 __GLX_VENDOR_LIBRARY_NAME=nvidia <cmd>

export MOZ_DISABLE_RDD_SANDBOX=1

# Cursors
export HYPRCURSOR_THEME=macOS-hyper
export HYPRCURSOR_SIZE=24
export XCURSOR_SIZE=24
export XCURSOR_THEME=macOS

# Wayland compatibility
export SDL_VIDEODRIVER=wayland
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM=wayland
# 1Password breaks with these settings for now
export ELECTRON_OZONE_PLATFORM_HINT=wayland
export OZONE_PLATFORM=wayland

# Qt
export QT_QPA_PLATFORMTHEME=qt6ct

# Restrict Hyprland's aquamarine backend to AMD only — prevents it from opening
# the NVIDIA DRM node and advertising the NVIDIA render node to Wayland clients
# (which causes hyprpaper and others to open /dev/nvidia0 and wake the dGPU).
# If HDMI is ever needed via the NVIDIA port, remove this.
export AQ_DRM_DEVICES=/dev/dri/card2

# Prefer AMD Vulkan (RADV) for all desktop apps.
# vulkan-radeon must be installed for this ICD to exist.
# For NVIDIA offload: __NV_PRIME_RENDER_OFFLOAD=1 __VK_LAYER_NV_optimus=NVIDIA_only VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json <cmd>
export VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.json
